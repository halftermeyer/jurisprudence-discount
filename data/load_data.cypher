// ============================================================
// Jurisprudence demo — generated by generate_data.py
// Step 0: Clean database
// ============================================================
MATCH (n) DETACH DELETE n;

CREATE CONSTRAINT customer_id IF NOT EXISTS FOR (n:Customer) REQUIRE n.id IS UNIQUE;

CREATE CONSTRAINT order_id IF NOT EXISTS FOR (n:Order) REQUIRE n.id IS UNIQUE;

CREATE CONSTRAINT incident_id IF NOT EXISTS FOR (n:Incident) REQUIRE n.id IS UNIQUE;

CREATE CONSTRAINT policy_id IF NOT EXISTS FOR (n:Policy) REQUIRE n.id IS UNIQUE;

CREATE CONSTRAINT case_id IF NOT EXISTS FOR (n:Case) REQUIRE n.id IS UNIQUE;

CREATE CONSTRAINT human_id IF NOT EXISTS FOR (n:Human) REQUIRE n.id IS UNIQUE;

CREATE CONSTRAINT precedent_id IF NOT EXISTS FOR (n:Precedent) REQUIRE n.id IS UNIQUE;

CREATE INDEX incident_type IF NOT EXISTS FOR (n:Incident) ON (n.type);

CREATE INDEX policy_incident_type IF NOT EXISTS FOR (n:Policy) ON (n.incident_type);

CREATE INDEX precedent_incident_type IF NOT EXISTS FOR (n:Precedent) ON (n.incident_type);

MERGE (p:Policy {id: 'POL-001'})
SET p.name = 'Transit Damage — Standard Care', p.incident_type = 'damaged_in_transit', p.min_tier = 'Standard',
    p.max_recency_days = 60, p.action = 'refund_or_replacement_plus_discount', p.discount_pct = 15,
    p.description = 'Product damaged in transit: offer replacement or refund plus a 15% goodwill discount on the next order.', p.source = 'customer_care_handbook_v7';

MERGE (p:Policy {id: 'POL-002'})
SET p.name = 'Transit Damage — Premium Care', p.incident_type = 'damaged_in_transit', p.min_tier = 'Gold',
    p.max_recency_days = 60, p.action = 'express_replacement_plus_discount', p.discount_pct = 20,
    p.description = 'Gold and VIP customers with transit damage get an express replacement and a 20% discount on the current order.', p.source = 'customer_care_handbook_v7';

MERGE (p:Policy {id: 'POL-003'})
SET p.name = 'Wrong Item Shipped', p.incident_type = 'wrong_item_shipped', p.min_tier = 'Standard',
    p.max_recency_days = 45, p.action = 'replacement_plus_apology_discount', p.discount_pct = 10,
    p.description = 'Wrong item shipped: send the correct item with prepaid return label and a 10% apology discount.', p.source = 'customer_care_handbook_v7';

MERGE (p:Policy {id: 'POL-004'})
SET p.name = 'Late Delivery Credit', p.incident_type = 'late_delivery', p.min_tier = 'Standard',
    p.max_recency_days = 30, p.action = 'shipping_credit', p.discount_pct = 10,
    p.description = 'Delivery later than promised: refund shipping fees and issue a 10% credit voucher.', p.source = 'customer_care_handbook_v7';

MERGE (p:Policy {id: 'POL-005'})
SET p.name = 'Quality Complaint Refund', p.incident_type = 'quality_complaint', p.min_tier = 'Standard',
    p.max_recency_days = 90, p.action = 'refund_after_review', p.discount_pct = 0,
    p.description = 'Substantiated quality complaints are refunded in full after a quality-team review. No discount.', p.source = 'customer_care_handbook_v7';

MERGE (p:Policy {id: 'POL-006'})
SET p.name = 'VIP White Glove', p.incident_type = 'quality_complaint', p.min_tier = 'VIP',
    p.max_recency_days = 90, p.action = 'refund_plus_discount', p.discount_pct = 25,
    p.description = 'VIP quality complaints: immediate refund, no review required, 25% discount on the next order.', p.source = 'customer_care_handbook_v7';

MERGE (p:Policy {id: 'POL-GAP'})
SET p.name = 'Policy Gap — uncovered incident types', p.incident_type = 'uncovered',
    p.min_tier = 'Standard', p.max_recency_days = null, p.action = 'escalate_to_human',
    p.discount_pct = null,
    p.description = 'Placeholder policy: incidents that no written policy covers. Precedents that fill the gap REFINE this node until the handbook is updated.',
    p.source = 'system';

MERGE (h:Human {id: 'HUM-001'}) SET h.name = 'Sophie Marchand', h.role = 'Customer Care Lead';

MERGE (h:Human {id: 'HUM-002'}) SET h.name = 'Karim Benali', h.role = 'Senior CS Manager';

