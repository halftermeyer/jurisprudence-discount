MATCH (i:Incident {id: 'INC-201'}), (h:Human {id: 'HUM-001'}), (gap:Policy {id: 'POL-GAP'})
MERGE (cs:Case {id: 'CASE-201'}) SET cs.opened_at = date('2026-04-04'), cs.status = 'resolved_by_human'
MERGE (cs)-[:CONCERNS]->(i)
MERGE (cs)-[:DECIDED_BY]->(h)
MERGE (pr:Precedent {id: 'PR-001'})
SET pr.established_at = date('2026-04-04'), pr.incident_type = 'gift_missing_from_set',
    pr.min_tier = 'Standard', pr.action = 'ship_missing_item_plus_discount', pr.discount_pct = 5,
    pr.rationale = 'Missing gift-with-purchase: ship the missing item and apply a 5% goodwill discount. No refund of the set.'
MERGE (h)-[:ESTABLISHES]->(pr)
MERGE (pr)-[:REFINES]->(gap)
SET i.resolution_type = 'human', i.resolution_ref = 'PR-001',
    i.resolution_action = 'ship_missing_item_plus_discount', i.resolution_discount_pct = 5,
    i.resolved_at = date('2026-04-04');

